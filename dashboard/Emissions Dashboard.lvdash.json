{
  "datasets": [
    {
      "name": "53150fbf",
      "displayName": "Location Data",
      "queryLines": [
        "select \r\n",
        "    latitude,\r\n",
        "    longitude,\r\n",
        "    `GHG emissions mtons CO2e` as emissions\r\n",
        "\r\n",
        "from emissions.default.emissions_data"
      ]
    },
    {
      "name": "784a218e",
      "displayName": "Emissions per Person",
      "queryLines": [
        "select\r\n",
        "    county_state_name,\r\n",
        "    population,\r\n",
        "    cast(REPLACE(`GHG emissions mtons CO2e`, ',', '') as double) / NULLIF(cast(population as double), 0) as EmissionsPerPerson\r\n",
        "from emissions.default.emissions_data\r\n",
        "order by emissionsperperson desc\r\n"
      ],
      "catalog": "emissions",
      "schema": "default"
    },
    {
      "name": "b464c0ac",
      "displayName": "Emissions Per State",
      "queryLines": [
        "select\r\n",
        "  state_abbr,\r\n",
        "  SUM(cast(REPLACE(`GHG emissions mtons CO2e`, ',', '') as double)) as TotalEmissionByState\r\n",
        "from\r\n",
        "  emissions.default.emissions_data\r\n",
        "group by\r\n",
        "  state_abbr\r\n",
        "order by\r\n",
        "  TotalEmissionByState desc\r\n",
        "  limit 10\r\n"
      ],
      "catalog": "emissions",
      "schema": "default"
    },
    {
      "name": "0e69a2e1",
      "displayName": "County Shaming",
      "queryLines": [
        "select county_state_name,\r\n",
        "        population,\r\n",
        "        cast(\r\n",
        "            replace(`GHG emissions mtons CO2e`, ',', '') as double\r\n",
        "        ) as Total_Emissions\r\n",
        "        from emissions.default.emissions_data\r\n",
        "\r\n",
        "order by Total_Emissions desc\r\n",
        "limit 10"
      ],
      "catalog": "emissions",
      "schema": "default"
    }
  ],
